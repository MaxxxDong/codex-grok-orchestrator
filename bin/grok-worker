#!/usr/bin/env bash
# Source-checkout launcher. Package installs expose the same command through
# the Python console entry point.
set -euo pipefail

resolve_skill_root() {
  if [ -n "${GROK_WORKER_SKILL_ROOT:-}" ]; then
    printf '%s\n' "$GROK_WORKER_SKILL_ROOT"
    return
  fi
  local here
  here="$(cd "$(dirname "$0")" && pwd)"
  # Candidate / co-located layout: bin/ next to src/
  if [ -d "$here/../src/grok_worker" ]; then
    cd "$here/.." && pwd
    return
  fi
  echo "grok-worker: cannot locate repository root (set GROK_WORKER_SKILL_ROOT)" >&2
  exit 1
}

ROOT="$(resolve_skill_root)"
export PYTHONPATH="${ROOT}/src${PYTHONPATH:+:$PYTHONPATH}"

# Shared CLI cache outside any clone; mirrors the Python cache-root contract.
CACHE_EXPLICIT=0
if [ -n "${GROK_WORKER_CACHE_ROOT:-}" ]; then
  CACHE_ROOT="$GROK_WORKER_CACHE_ROOT"
  CACHE_EXPLICIT=1
elif [ -n "${XDG_CACHE_HOME:-}" ]; then
  CACHE_ROOT="$XDG_CACHE_HOME/grok-worker"
elif [ "$(uname -s)" = "Darwin" ]; then
  CACHE_ROOT="$HOME/Library/Caches/grok-worker"
else
  CACHE_ROOT="$HOME/.cache/grok-worker"
fi

ensure_private_writable_dir() {
  local directory="$1" probe
  [ ! -L "$directory" ] || return 1
  (umask 077 && mkdir -p "$directory") 2>/dev/null || return 1
  [ -d "$directory" ] && [ -O "$directory" ] || return 1
  chmod 700 "$directory" 2>/dev/null || return 1
  probe="$directory/.grok-worker-write-probe-$$"
  mkdir -m 700 "$probe" 2>/dev/null || return 1
  rmdir "$probe" 2>/dev/null || return 1
}

CLI_CACHE="$CACHE_ROOT/cli"
if ! ensure_private_writable_dir "$CACHE_ROOT" || ! ensure_private_writable_dir "$CLI_CACHE"; then
  if [ "$CACHE_EXPLICIT" -eq 1 ]; then
    echo "grok-worker: configured cache root is not writable: $CACHE_ROOT" >&2
    exit 1
  fi
  CACHE_ROOT="${TMPDIR:-/tmp}/grok-worker-$(id -u)"
  CLI_CACHE="$CACHE_ROOT/cli"
  ensure_private_writable_dir "$CACHE_ROOT" && ensure_private_writable_dir "$CLI_CACHE" || {
    echo "grok-worker: no writable cache root available" >&2
    exit 1
  }
  echo "grok-worker: warning: default cache was not writable; using $CACHE_ROOT" >&2
fi
export GROK_WORKER_CACHE_ROOT="$CACHE_ROOT"

UV_CACHE_CANDIDATE="${UV_CACHE_DIR:-$CACHE_ROOT/uv}"
if ! ensure_private_writable_dir "$UV_CACHE_CANDIDATE"; then
  UV_CACHE_CANDIDATE="$CACHE_ROOT/uv"
  ensure_private_writable_dir "$UV_CACHE_CANDIDATE" || {
    echo "grok-worker: no writable uv cache available" >&2
    exit 1
  }
  echo "grok-worker: warning: configured uv cache was not writable; using $UV_CACHE_CANDIDATE" >&2
fi
export UV_CACHE_DIR="$UV_CACHE_CANDIDATE"

python_ready() {
  "$1" -c 'import importlib.metadata as m, sys; raise SystemExit(0 if sys.version_info >= (3, 12) and m.version("typer") == "0.15.2" and m.version("click") == "8.1.8" else 1)' >/dev/null 2>&1
}

if [ -x "$ROOT/.venv/bin/python" ] && python_ready "$ROOT/.venv/bin/python"; then
  exec "$ROOT/.venv/bin/python" -m grok_worker "$@"
fi

for cand in python3.14 python3.13 python3.12 python3; do
  if command -v "$cand" >/dev/null 2>&1 && python_ready "$cand"; then
    exec "$cand" -m grok_worker "$@"
  fi
done

if ! command -v uv >/dev/null 2>&1; then
  echo "grok-worker: run 'uv sync --extra dev' once or install Python 3.12+ with Typer 0.15.2 and Click 8.1.8" >&2
  exit 1
fi

# Pin Typer+Click deterministically via shared uv cache (never a clone-local env)
PINNED_TYPER="${GROK_WORKER_TYPER_SPEC:-typer==0.15.2}"
PINNED_CLICK="${GROK_WORKER_CLICK_SPEC:-click==8.1.8}"
exec uv run --no-project --with "$PINNED_TYPER" --with "$PINNED_CLICK" \
  python -m grok_worker "$@"
